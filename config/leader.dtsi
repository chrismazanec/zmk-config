#undef ZMK_LEADER_SEQUENCE
#define ZMK_LEADER_SEQUENCE(name, leader_bindings, leader_sequence) \
    / { \
        behaviors { \
            leader: leader { \
                compatible = "zmk,behavior-leader-key"; \
                #binding-cells = <0>; \
                ignore-keys = <LSHFT RSHFT>; \
                leader_sequence_ ## name { \
                    bindings = <leader_bindings>; \
                    sequence = <leader_sequence>; \
                }; \
            }; \
        }; \
    };

#define ZMK_LEADER_UP_SEQUENCE(name, leader_bindings, leader_sequence) \
    / { \
        behaviors { \
            leader_up: leader_up { \
                compatible = "zmk,behavior-leader-key"; \
                #binding-cells = <0>; \
                leader_sequence_ ## name { \
                    bindings = <leader_bindings>; \
                    sequence = <leader_sequence>; \
                }; \
            }; \
        }; \
    };

/* Slovak dead key macros for ABC Extended (macOS)
 * Uses Right Alt (RALT) for dead keys — Alacritty passes right Option through
 * to macOS while left Option is sent as Alt to tmux/fish.
 * Acute:      RAlt+E → letter
 * Caron:      RAlt+V → letter
 * Umlaut:     RAlt+U → letter
 * Circumflex: RAlt+6 → letter
 *
 * Uppercase variants send dead key then Shift+letter.
 * Triggered via separate leader_up behavior (3-key combo), so no shift
 * interference with the dead key.
 */

// --- lowercase ---
ZMK_MACRO(sk_m_aa, wait-ms = <30>; tap-ms = <30>; bindings = <&kp RA(E)>, <&kp A>;)   // á
ZMK_MACRO(sk_m_ea, wait-ms = <30>; tap-ms = <30>; bindings = <&kp RA(E)>, <&kp E>;)   // é
ZMK_MACRO(sk_m_ia, wait-ms = <30>; tap-ms = <30>; bindings = <&kp RA(E)>, <&kp I>;)   // í
ZMK_MACRO(sk_m_oa, wait-ms = <30>; tap-ms = <30>; bindings = <&kp RA(E)>, <&kp O>;)   // ó
ZMK_MACRO(sk_m_ua, wait-ms = <30>; tap-ms = <30>; bindings = <&kp RA(E)>, <&kp U>;)   // ú
ZMK_MACRO(sk_m_ya, wait-ms = <30>; tap-ms = <30>; bindings = <&kp RA(E)>, <&kp Y>;)   // ý
ZMK_MACRO(sk_m_ra, wait-ms = <30>; tap-ms = <30>; bindings = <&kp RA(E)>, <&kp R>;)   // ŕ
ZMK_MACRO(sk_m_cc, wait-ms = <30>; tap-ms = <30>; bindings = <&kp RA(V)>, <&kp C>;)   // č
ZMK_MACRO(sk_m_sc, wait-ms = <30>; tap-ms = <30>; bindings = <&kp RA(V)>, <&kp S>;)   // š
ZMK_MACRO(sk_m_zc, wait-ms = <30>; tap-ms = <30>; bindings = <&kp RA(V)>, <&kp Z>;)   // ž
ZMK_MACRO(sk_m_dc, wait-ms = <30>; tap-ms = <30>; bindings = <&kp RA(V)>, <&kp D>;)   // ď
ZMK_MACRO(sk_m_tc, wait-ms = <30>; tap-ms = <30>; bindings = <&kp RA(V)>, <&kp T>;)   // ť
ZMK_MACRO(sk_m_nc, wait-ms = <30>; tap-ms = <30>; bindings = <&kp RA(V)>, <&kp N>;)   // ň
ZMK_MACRO(sk_m_lc, wait-ms = <30>; tap-ms = <30>; bindings = <&kp RA(V)>, <&kp L>;)   // ľ
ZMK_MACRO(sk_m_ad, wait-ms = <30>; tap-ms = <30>; bindings = <&kp RA(U)>, <&kp A>;)   // ä
ZMK_MACRO(sk_m_ox, wait-ms = <30>; tap-ms = <30>; bindings = <&kp RA(N6)>, <&kp O>;)  // ô

// --- UPPERCASE (dead key → Shift+letter) ---
ZMK_MACRO(sku_aa, wait-ms = <30>; tap-ms = <30>; bindings = <&kp RA(E)>, <&kp LS(A)>;)   // Á
ZMK_MACRO(sku_ea, wait-ms = <30>; tap-ms = <30>; bindings = <&kp RA(E)>, <&kp LS(E)>;)   // É
ZMK_MACRO(sku_ia, wait-ms = <30>; tap-ms = <30>; bindings = <&kp RA(E)>, <&kp LS(I)>;)   // Í
ZMK_MACRO(sku_oa, wait-ms = <30>; tap-ms = <30>; bindings = <&kp RA(E)>, <&kp LS(O)>;)   // Ó
ZMK_MACRO(sku_ua, wait-ms = <30>; tap-ms = <30>; bindings = <&kp RA(E)>, <&kp LS(U)>;)   // Ú
ZMK_MACRO(sku_ya, wait-ms = <30>; tap-ms = <30>; bindings = <&kp RA(E)>, <&kp LS(Y)>;)   // Ý
ZMK_MACRO(sku_ra, wait-ms = <30>; tap-ms = <30>; bindings = <&kp RA(E)>, <&kp LS(R)>;)   // Ŕ
ZMK_MACRO(sku_cc, wait-ms = <30>; tap-ms = <30>; bindings = <&kp RA(V)>, <&kp LS(C)>;)   // Č
ZMK_MACRO(sku_sc, wait-ms = <30>; tap-ms = <30>; bindings = <&kp RA(V)>, <&kp LS(S)>;)   // Š
ZMK_MACRO(sku_zc, wait-ms = <30>; tap-ms = <30>; bindings = <&kp RA(V)>, <&kp LS(Z)>;)   // Ž
ZMK_MACRO(sku_dc, wait-ms = <30>; tap-ms = <30>; bindings = <&kp RA(V)>, <&kp LS(D)>;)   // Ď
ZMK_MACRO(sku_tc, wait-ms = <30>; tap-ms = <30>; bindings = <&kp RA(V)>, <&kp LS(T)>;)   // Ť
ZMK_MACRO(sku_nc, wait-ms = <30>; tap-ms = <30>; bindings = <&kp RA(V)>, <&kp LS(N)>;)   // Ň
ZMK_MACRO(sku_lc, wait-ms = <30>; tap-ms = <30>; bindings = <&kp RA(V)>, <&kp LS(L)>;)   // Ľ
ZMK_MACRO(sku_ad, wait-ms = <30>; tap-ms = <30>; bindings = <&kp RA(U)>, <&kp LS(A)>;)   // Ä
ZMK_MACRO(sku_ox, wait-ms = <30>; tap-ms = <30>; bindings = <&kp RA(N6)>, <&kp LS(O)>;)  // Ô

/* Slovak characters — leader (2-key combo) → lowercase */
ZMK_LEADER_SEQUENCE(sk_aa,   &sk_m_aa,   A)  // á
ZMK_LEADER_SEQUENCE(sk_ea,   &sk_m_ea,   E)  // é
ZMK_LEADER_SEQUENCE(sk_ia,   &sk_m_ia,   I)  // í
ZMK_LEADER_SEQUENCE(sk_oa,   &sk_m_oa,   O)  // ó
ZMK_LEADER_SEQUENCE(sk_ua,   &sk_m_ua,   U)  // ú
ZMK_LEADER_SEQUENCE(sk_ya,   &sk_m_ya,   Y)  // ý
ZMK_LEADER_SEQUENCE(sk_ad,   &sk_m_ad,   W)  // ä
ZMK_LEADER_SEQUENCE(sk_ox,   &sk_m_ox,   X)  // ô
ZMK_LEADER_SEQUENCE(sk_cc,   &sk_m_cc,   C)  // č
ZMK_LEADER_SEQUENCE(sk_sc,   &sk_m_sc,   S)  // š
ZMK_LEADER_SEQUENCE(sk_zc,   &sk_m_zc,   Z)  // ž
ZMK_LEADER_SEQUENCE(sk_dc,   &sk_m_dc,   D)  // ď
ZMK_LEADER_SEQUENCE(sk_tc,   &sk_m_tc,   T)  // ť
ZMK_LEADER_SEQUENCE(sk_nc,   &sk_m_nc,   N)  // ň
ZMK_LEADER_SEQUENCE(sk_lc,   &sk_m_lc,   L)  // ľ
ZMK_LEADER_SEQUENCE(sk_ra,   &sk_m_ra,   R)  // ŕ

// BLE and USB
#ifdef CONFIG_WIRELESS
ZMK_LEADER_SEQUENCE(usb,        &out OUT_USB,   U S B)
ZMK_LEADER_SEQUENCE(ble,        &out OUT_BLE,   B L E)
#endif // CONFIG_WIRELESS
ZMK_LEADER_SEQUENCE(reset,      &sys_reset,     R E S E T)
ZMK_LEADER_SEQUENCE(boot,       &bootloader,    B O O T)

/* Slovak characters — leader_up (3-key combo) → UPPERCASE */
ZMK_LEADER_UP_SEQUENCE(up_aa,   &sku_aa,   A)  // Á
ZMK_LEADER_UP_SEQUENCE(up_ea,   &sku_ea,   E)  // É
ZMK_LEADER_UP_SEQUENCE(up_ia,   &sku_ia,   I)  // Í
ZMK_LEADER_UP_SEQUENCE(up_oa,   &sku_oa,   O)  // Ó
ZMK_LEADER_UP_SEQUENCE(up_ua,   &sku_ua,   U)  // Ú
ZMK_LEADER_UP_SEQUENCE(up_ya,   &sku_ya,   Y)  // Ý
ZMK_LEADER_UP_SEQUENCE(up_ad,   &sku_ad,   W)  // Ä
ZMK_LEADER_UP_SEQUENCE(up_ox,   &sku_ox,   X)  // Ô
ZMK_LEADER_UP_SEQUENCE(up_cc,   &sku_cc,   C)  // Č
ZMK_LEADER_UP_SEQUENCE(up_sc,   &sku_sc,   S)  // Š
ZMK_LEADER_UP_SEQUENCE(up_zc,   &sku_zc,   Z)  // Ž
ZMK_LEADER_UP_SEQUENCE(up_dc,   &sku_dc,   D)  // Ď
ZMK_LEADER_UP_SEQUENCE(up_tc,   &sku_tc,   T)  // Ť
ZMK_LEADER_UP_SEQUENCE(up_nc,   &sku_nc,   N)  // Ň
ZMK_LEADER_UP_SEQUENCE(up_lc,   &sku_lc,   L)  // Ľ
ZMK_LEADER_UP_SEQUENCE(up_ra,   &sku_ra,   R)  // Ŕ
